# =============================================================================
# SEADROP MINT BOT — ENVIRONMENT CONFIGURATION
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
ADMIN_TELEGRAM_ID=

# -----------------------------------------------------------------------------
# RPC
# -----------------------------------------------------------------------------
ALCHEMY_API_KEY=
BACKUP_RPC_URL=https://cloudflare-eth.com

# -----------------------------------------------------------------------------
# OpenSea API v2
# -----------------------------------------------------------------------------
OPENSEA_API_KEY=

# -----------------------------------------------------------------------------
# Etherscan
# -----------------------------------------------------------------------------
ETHERSCAN_API_KEY=

# -----------------------------------------------------------------------------
# Wallets (up to 100 EOA burner wallets)
# WARNING: These are plaintext private keys. Protect this file.
# Use burner wallets only. Never use wallets with significant funds.
# -----------------------------------------------------------------------------
WALLET_1_KEY=
WALLET_2_KEY=
WALLET_3_KEY=
# WALLET_4_KEY=
# WALLET_5_KEY=
# ... up to WALLET_100_KEY=

# -----------------------------------------------------------------------------
# Mint Defaults (overridable per user via /set_* commands)
# -----------------------------------------------------------------------------
DEFAULT_MAX_MINT_PRICE_ETH=0.1
DEFAULT_MAX_GAS_ETH=0.02
DEFAULT_QUANTITY=1
LOW_BALANCE_THRESHOLD_ETH=0.05
MAX_PRIORITY_FEE_GWEI=0.1
TX_TIMEOUT_SECONDS=300
QUEUE_CONCURRENCY=10

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# GoPlus Security
# Set to true to block mints when GoPlus API is unavailable
# -----------------------------------------------------------------------------
GOPLUS_STRICT_MODE=false

# -----------------------------------------------------------------------------
# Dry Run Mode
# Set to true to force ALL /mint commands to run as simulations.
# No transactions are ever sent while this is enabled.
# -----------------------------------------------------------------------------
DRY_RUN_MODE=false

# -----------------------------------------------------------------------------
# Redis (optional — enables BullMQ persistent queue)
# If not set, p-queue in-memory queue is used
# -----------------------------------------------------------------------------
# REDIS_URL=redis://localhost:6379
