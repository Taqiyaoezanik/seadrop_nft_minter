{
  "name": "seadrop-mint-bot",
  "version": "1.0.0",
  "description": "Open source Telegram bot for minting NFTs from OpenSea SeaDrop collections",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "telegraf": "4.16.3",
    "viem": "2.21.19",
    "better-sqlite3": "9.4.3",
    "p-queue": "8.0.1",
    "bullmq": "5.7.8",
    "ioredis": "5.3.2",
    "axios": "1.6.8",
    "winston": "3.13.0",
    "dotenv": "16.4.5",
    "uuid": "9.0.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "7.6.8",
    "@types/node": "20.12.7",
    "@types/uuid": "9.0.8",
    "@types/axios": "0.14.4",
    "typescript": "5.4.5",
    "ts-node-dev": "2.0.0",
    "@typescript-eslint/eslint-plugin": "7.8.0",
    "@typescript-eslint/parser": "7.8.0",
    "eslint": "8.57.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
